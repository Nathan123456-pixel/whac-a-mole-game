    const eggKey = pickAhEgg();
    if (eggKey) {
      const pool = EGG_POOLS[eggKey];
      spendCoins(pool.price);
      const animal = rollAnimal(eggKey);
      const currentCount = collection.filter(a => a.eggType===eggKey && a.id===animal.id).length;
      const maxStack = MAX_STACK[animal.rarity];
      const isMaxed = currentCount >= maxStack;
      if (!isMaxed) { collection.push({...animal, eggType:eggKey}); ls_set('wam_collection', collection); }
      renderShopEggs(); renderCollection();
      updateCoinDisplay();
    }
    updateAhStatus();
    if (ahEnabled) {
      ahProgressStart = Date.now();
