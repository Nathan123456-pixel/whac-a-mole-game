}
function ckEndGame() {
  CK.running = false;
  cancelAnimationFrame(CK.rafId);
  clearTimeout(CK.holeSpawnTimer); clearTimeout(CK.moleSpawnTimer);
  CK.holes.forEach(h => { clearTimeout(h.moleTimer); if(h.el) h.el.remove(); });
