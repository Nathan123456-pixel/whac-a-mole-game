// PARKOUR MODE
// ═══════════════════════════════════════════════════════════════════════════
const PK = {
  running: false,
  score: 0,
  startTime: 0,
  moles: [],
  platforms: [],
  rafId: null,
  spawnTimer: null,
  canvas: null,
  ctx: null,
  lastTime: 0
};
const PK_MOLE_SIZE = 40;
const PK_PLATFORM_H = 18;
function pkSetupCanvas() {
  PK.canvas = document.getElementById('pkCanvas');
  if (!PK.canvas) return;
  PK.ctx = PK.canvas.getContext('2d');
  PK.canvas.addEventListener('click', pkHandleClick);
  PK.canvas.addEventListener('touchstart', pkHandleTouch, { passive: false });
}
function pkHandleClick(e) {
  if (!PK.running) return;
  const rect = PK.canvas.getBoundingClientRect();
  const scaleX = PK.canvas.width / rect.width;
  const scaleY = PK.canvas.height / rect.height;
  const x = (e.clientX - rect.left) * scaleX;
  const y = (e.clientY - rect.top) * scaleY;
  pkTryWhack(x, y);
}
function pkHandleTouch(e) {
  if (!PK.running) return;
  e.preventDefault();
  const touch = e.touches[0];
  const rect = PK.canvas.getBoundingClientRect();
  const scaleX = PK.canvas.width / rect.width;
  const scaleY = PK.canvas.height / rect.height;
  const x = (touch.clientX - rect.left) * scaleX;
  const y = (touch.clientY - rect.top) * scaleY;
  pkTryWhack(x, y);
}
function pkTryWhack(x, y) {
  for (let i = PK.moles.length - 1; i >= 0; i--) {
    const m = PK.moles[i];
    if (m.hit) continue;
    const dx = x - m.x;
    const dy = y - m.y;
    if (dx*dx + dy*dy < (PK_MOLE_SIZE * 0.7) ** 2) {
      m.hit = true;
      m.hitTime = Date.now();
      PK.score++;
      addCoins(DIFFS[diff].coins);
      break;
    }
  }
}
function pkStartGame() {
  PK.running = true;
  PK.score = 0;
  PK.moles = [];
  PK.platforms = [
    { x: 50, y: 280, w: 120 },
    { x: 200, y: 220, w: 100 },
    { x: 350, y: 160, w: 130 },
    { x: 480, y: 240, w: 90 },
    { x: 100, y: 120, w: 110 },
  ];
  document.getElementById('overlay').classList.add('hidden');
  pkSpawnLoop();
  PK.lastTime = performance.now();
  PK.rafId = requestAnimationFrame(pkLoop);
}
function pkSpawnLoop() {
  if (!PK.running) return;
  const plat = PK.platforms[Math.floor(Math.random() * PK.platforms.length)];
  PK.moles.push({
    x: -PK_MOLE_SIZE,
    y: plat.y - PK_MOLE_SIZE / 2,
    vx: 80 + Math.random() * 60,
    vy: 0,
    onGround: true,
    hit: false,
    hitTime: 0
  });
  const interval = DIFFS[diff].interval * (0.8 + Math.random() * 0.4);
  PK.spawnTimer = setTimeout(pkSpawnLoop, interval);
}
function pkLoop(ts) {
  const dt = Math.min((ts - PK.lastTime) / 1000, 0.05);
  PK.lastTime = ts;
  
  // Timer
  const elapsed = (Date.now() - PK.startTime) / 1000;
  const timeLeft = Math.max(0, GAME_DURATION - elapsed);
  
  if (timeLeft <= 0) {
    pkEndGame();
    return;
  }
  
  // Update moles
  for (const m of PK.moles) {
    if (m.hit) continue;
    m.x += m.vx * dt;
    m.vy += 400 * dt; // gravity
    m.y += m.vy * dt;
    
    // Platform collision
    for (const p of PK.platforms) {
      if (m.x > p.x - PK_MOLE_SIZE/2 && m.x < p.x + p.w + PK_MOLE_SIZE/2) {
        if (m.y >= p.y - PK_MOLE_SIZE/2 && m.y - m.vy * dt < p.y - PK_MOLE_SIZE/2) {
          m.y = p.y - PK_MOLE_SIZE/2;
          m.vy = 0;
          m.onGround = true;
          // Random jump
          if (Math.random() < 0.02) {
            m.vy = -200 - Math.random() * 100;
            m.onGround = false;
          }
        }
      }
    }
  }
  
  // Remove off-screen or old hit moles
  PK.moles = PK.moles.filter(m => {
    if (m.hit && Date.now() - m.hitTime > 500) return false;
    if (m.x > PK.canvas.width + PK_MOLE_SIZE) return false;
    if (m.y > PK.canvas.height + PK_MOLE_SIZE) return false;
    return true;
  });
  
  // Draw
  pkDraw(timeLeft);
  
  PK.rafId = requestAnimationFrame(pkLoop);
}
function pkDraw(timeLeft) {
  const ctx = PK.ctx;
  const W = PK.canvas.width;
  const H = PK.canvas.height;
  
  // Background
  ctx.fillStyle = '#1a0a2a';
  ctx.fillRect(0, 0, W, H);
  
  // Platforms
  ctx.fillStyle = '#5c3318';
  for (const p of PK.platforms) {
    ctx.beginPath();
    ctx.roundRect(p.x, p.y, p.w, PK_PLATFORM_H, 6);
    ctx.fill();
  }
  
  // Moles
  for (const m of PK.moles) {
    ctx.save();
    ctx.translate(m.x, m.y);
    if (m.hit) {
      const elapsed = Date.now() - m.hitTime;
      ctx.globalAlpha = Math.max(0, 1 - elapsed / 500);
      ctx.rotate(elapsed * 0.02);
      ctx.scale(1 + elapsed * 0.002, 1 + elapsed * 0.002);
    }
    // Simple mole circle representation
    ctx.fillStyle = '#8B5E3C';
    ctx.beginPath();
    ctx.arc(0, 0, PK_MOLE_SIZE / 2, 0, Math.PI * 2);
    ctx.fill();
    // Face
    ctx.fillStyle = '#C8967A';
    ctx.beginPath();
    ctx.arc(0, 2, PK_MOLE_SIZE / 3, 0, Math.PI * 2);
    ctx.fill();
    // Eyes
    ctx.fillStyle = 'white';
    ctx.beginPath();
    ctx.arc(-6, -4, 5, 0, Math.PI * 2);
    ctx.arc(6, -4, 5, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#1a1a1a';
    ctx.beginPath();
    ctx.arc(-5, -3, 2.5, 0, Math.PI * 2);
    ctx.arc(7, -3, 2.5, 0, Math.PI * 2);
    ctx.fill();
    // Nose
    ctx.fillStyle = '#cc6060';
    ctx.beginPath();
    ctx.arc(0, 4, 4, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }
  
  // HUD
  ctx.fillStyle = '#c9a8ff';
  ctx.font = 'bold 18px system-ui';
  ctx.textAlign = 'left';
  ctx.fillText(`Score: ${PK.score}`, 15, 28);
  ctx.textAlign = 'right';
  ctx.fillText(`Time: ${Math.ceil(timeLeft)}s`, W - 15, 28);
}
function pkEndGame() {
  PK.running = false;
  cancelAnimationFrame(PK.rafId);
  clearTimeout(PK.spawnTimer);
  
  const s = PK.score;
  if (s > best) { best = s; ls_set('wam_best', best); }
