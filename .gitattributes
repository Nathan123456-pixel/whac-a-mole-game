<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Whack-a-Mole</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#1b0f2e;font-family:system-ui,sans-serif;color:#f0eaff;padding:1rem 1rem 3rem}
h1{font-size:2.2rem;font-weight:800;letter-spacing:2px;color:#c9a8ff;margin-bottom:1.2rem;text-shadow:0 0 20px #7c4dff44}
.hud{display:flex;gap:10px;margin-bottom:1.2rem;flex-wrap:wrap;justify-content:center}
.hud-box{background:#27164a;border:1px solid #4a2e80;border-radius:12px;padding:10px 20px;text-align:center;min-width:90px}
.hud-box.coin-box{border-color:#c8a000;background:#2a1e00}
.hud-box.p1-box{border-color:#7c4dff;background:#1a0a3a}
.hud-box.p2-box{border-color:#ff4d6d;background:#3a0a1a}
.hud-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:#9b78d4;margin-bottom:4px}
.hud-box.coin-box .hud-label{color:#c8a000}
.hud-box.p1-box .hud-label{color:#a87cff}
.hud-box.p2-box .hud-label{color:#ff8099}
.hud-value{font-size:2rem;font-weight:700;color:#e8d8ff}
.hud-box.coin-box .hud-value{color:#ffd740}
.hud-box.p1-box .hud-value{color:#c9a8ff}
.hud-box.p2-box .hud-value{color:#ff8099}
.timer-bar{width:100%;max-width:520px;height:8px;background:#27164a;border-radius:4px;overflow:hidden;margin-bottom:1rem}
.timer-fill{height:100%;width:100%;background:linear-gradient(90deg,#09ff00,#ff0000);border-radius:4px;transition:width .1s linear}
.timer-fill.low{background:linear-gradient(90deg,#ff4d6d,#ff9a3c)}
#ability-bar{width:100%;max-width:520px;margin-bottom:0.8rem;min-height:36px;display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap}
.ability-pill{display:inline-flex;align-items:center;gap:8px;background:#1f0d3a;border:1px solid #7c4dff;border-radius:30px;padding:6px 16px;font-size:0.85rem;font-weight:600;color:#c9a8ff;animation:pillPulse 1.5s infinite}
.ability-pill.shield{border-color:#00e5a0;color:#00e5a0;background:#00150d}
.ability-pill.coins{border-color:#ffd740;color:#ffd740;background:#1a1000}
.ability-pill.frenzy{border-color:#ff6b35;color:#ff6b35;background:#1a0500}
@keyframes pillPulse{0%,100%{opacity:1}50%{opacity:.7}}
#game-area{display:flex;gap:24px;width:100%;max-width:1080px;justify-content:center;flex-wrap:wrap}
.player-section{display:flex;flex-direction:column;align-items:center;flex:1;min-width:280px;max-width:520px}
.player-header{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:520px;margin-bottom:8px;padding:0 2px}
.player-tag{font-size:.8rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:4px 14px;border-radius:20px}
.player-tag.p1-tag{background:#2a1060;color:#c9a8ff;border:1px solid #7c4dff}
.player-tag.p2-tag{background:#3a0a1a;color:#ff8099;border:1px solid #ff4d6d}
.key-hint{font-size:.72rem;color:#5a3a80;letter-spacing:.5px}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;width:100%;margin-bottom:1rem}
#game-area:not(.dual) .grid{max-width:520px}
#game-area.dual .grid{max-width:420px;gap:10px}
.hole{aspect-ratio:1;background:#2a1a4a;border:1px solid #4a2e80;border-radius:16px;overflow:hidden;position:relative;cursor:pointer;transition:background .1s}
.hole:hover{background:#3a2060}
.hole.p2-hole:hover{background:#3a1030}
.hole::after{content:'';position:absolute;bottom:0;left:0;right:0;height:28%;background:#5c3318;border-radius:0 0 16px 16px}
.hole::before{content:'';position:absolute;bottom:26%;left:0;right:0;height:10px;background:#7a4a26;border-radius:50%;z-index:1}
.mole{position:absolute;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);transition:transform .18s cubic-bezier(.34,1.56,.64,1);z-index:2;pointer-events:none;width:62%}
.hole.up .mole{transform:translateX(-50%) translateY(12%)}
.hole.bonk .mole{transform:translateX(-50%) translateY(12%) rotate(-380deg) scale(.88)}
.mole svg{width:100%;height:auto;display:block}
.flash{position:absolute;inset:0;border-radius:16px;background:rgba(255,230,60,.35);opacity:0;pointer-events:none;z-index:5;transition:opacity .15s}
.hole.bonk .flash{opacity:1}
.p2-hole .flash{background:rgba(255,100,150,.4)}
.pop{position:absolute;top:18%;left:50%;transform:translateX(-50%);font-size:1.1rem;font-weight:800;color:#ffd740;opacity:0;pointer-events:none;z-index:6;white-space:nowrap}
@keyframes popUp{0%{opacity:1;transform:translateX(-50%) translateY(0)}80%{opacity:1;transform:translateX(-50%) translateY(-22px)}100%{opacity:0;transform:translateX(-50%) translateY(-30px)}}
.pop.show{animation:popUp .5s ease-out forwards}
.shop-btn{width:100%;max-width:520px;padding:12px;font-size:1rem;font-weight:700;font-family:inherit;letter-spacing:1px;background:#2a1e00;color:#ffd740;border:1px solid #c8a000;border-radius:12px;cursor:pointer;transition:background .15s,transform .1s;margin-bottom:1rem}
.shop-btn:hover{background:#3a2a00}
.shop-btn:active{transform:scale(.98)}
.high-scores{width:100%;max-width:520px;background:#27164a;border:1px solid #4a2e80;border-radius:16px;padding:1.2rem 1.5rem}
.high-scores h2{font-size:.85rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#9b78d4;margin-bottom:.7rem}
.hs-tabs{display:flex;gap:5px;margin-bottom:.9rem;flex-wrap:wrap}
.hs-tab{flex:1;padding:5px 0;border-radius:7px;border:1px solid #2a1060;background:transparent;color:#6a4a9a;font-size:.72rem;font-weight:700;font-family:inherit;cursor:pointer;text-transform:uppercase;letter-spacing:.5px;transition:background .12s;min-width:60px}
.hs-tab.active{background:#27164a;border-color:#7c4dff;color:#c9a8ff}
.hs-row{display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid #3a2060;font-size:.95rem}
.hs-row:last-child{border-bottom:none}
.hs-rank{font-size:.8rem;font-weight:700;color:#9b78d4;min-width:28px;text-align:center}
.hs-row:nth-child(1) .hs-rank{color:#ffd740;font-size:1rem}
.hs-row:nth-child(2) .hs-rank{color:#c0c0c0;font-size:1rem}
.hs-row:nth-child(3) .hs-rank{color:#cd7f32;font-size:1rem}
.hs-diff{font-size:.75rem;padding:2px 9px;border-radius:20px;font-weight:600;text-transform:capitalize}
.hs-diff.easy{background:#0d3320;color:#00ffbf}
.hs-diff.medium{background:#2a2200;color:#ffd740}
.hs-diff.hard{background:#3a0d0d;color:#ff6b6b}
.hs-diff.versus{background:#1a0a2a;color:#c9a8ff}
.hs-diff.parkour{background:#0a1a2a;color:#55aaff}
.hs-diff.chaos{background:#2a0a2a;color:#ff88ff}
.hs-pts{margin-left:auto;font-size:1.1rem;font-weight:700;color:#e8d8ff}
.hs-name{font-size:.82rem;color:#c9a8ff;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hs-name.hs-you{color:#ffd740}
/* name prompt overlay */
#name-overlay{position:fixed;inset:0;background:rgba(10,5,25,.92);display:flex;align-items:center;justify-content:center;z-index:500}
#name-overlay.hidden{display:none}
#name-overlay .nc{background:#1f1136;border:1px solid #4a2e80;border-radius:20px;padding:2.2rem 2.4rem;text-align:center;max-width:320px;width:88%}
#name-overlay h2{font-size:1.5rem;font-weight:800;color:#c9a8ff;margin-bottom:.4rem}
#name-overlay p{color:#9b78d4;font-size:.9rem;margin-bottom:1.2rem}
#name-input{width:100%;padding:10px 14px;font-size:1.1rem;font-family:inherit;background:#27164a;border:1.5px solid #4a2e80;border-radius:10px;color:#f0eaff;outline:none;text-align:center;margin-bottom:1rem;box-sizing:border-box}
#name-input:focus{border-color:#7c4dff}
#name-submit{width:100%;padding:11px;font-size:1rem;font-weight:700;font-family:inherit;background:#7c4dff;color:#fff;border:none;border-radius:10px;cursor:pointer;transition:background .15s}
#name-submit:hover{background:#9c6fff}
.hs-change-name{font-size:.72rem;color:#5a3a80;cursor:pointer;text-decoration:underline;display:block;text-align:center;margin-top:.6rem}
.hs-change-name:hover{color:#9b78d4}
.hs-footer{display:flex;justify-content:space-between;align-items:center;margin-top:.6rem}
.hs-reset-btn{font-size:.72rem;color:#5a2020;cursor:pointer;text-decoration:underline;background:none;border:none;font-family:inherit;padding:0}
.hs-reset-btn:hover{color:#cc4444}
/* reset confirm */
#reset-confirm{position:fixed;inset:0;background:rgba(10,5,25,.92);display:flex;align-items:center;justify-content:center;z-index:600}
#reset-confirm.hidden{display:none}
#reset-confirm .rc{background:#1a0808;border:1.5px solid #5a1010;border-radius:18px;padding:2rem 2.2rem;text-align:center;max-width:320px;width:88%}
#reset-confirm h2{font-size:1.3rem;font-weight:800;color:#ff8888;margin-bottom:.5rem}
#reset-confirm p{font-size:.85rem;color:#9b6060;margin-bottom:1.4rem;line-height:1.6}
.rc-items{text-align:left;background:#120404;border-radius:10px;padding:.8rem 1rem;margin-bottom:1.4rem;font-size:.82rem;color:#cc8888;line-height:2}
.rc-btns{display:flex;gap:10px;justify-content:center}
.rc-cancel{padding:9px 22px;border-radius:10px;border:1px solid #4a2e80;background:transparent;color:#9b78d4;font-size:.9rem;font-family:inherit;cursor:pointer}
.rc-cancel:hover{background:#27164a}
.rc-confirm{padding:9px 22px;border-radius:10px;border:none;background:#660000;color:#ffaaaa;font-size:.9rem;font-weight:700;font-family:inherit;cursor:pointer;transition:background .12s}
.rc-confirm:hover{background:#880000}
/* in-card leaderboard */
.card-scores{margin:1rem 0;background:#160d2e;border:1px solid #3a2060;border-radius:12px;padding:.7rem 1rem;text-align:left}
.card-scores-title{font-size:.72rem;text-transform:uppercase;letter-spacing:1.2px;color:#6a4a9a;font-weight:700;margin-bottom:.6rem}
.cs-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid #2a1060;font-size:.85rem}
.cs-row:last-child{border-bottom:none}
.cs-row.you{background:#1a0d3a;border-radius:8px;padding:5px 6px;margin:-1px -4px}
.cs-rank{min-width:22px;font-size:.8rem;font-weight:700;color:#9b78d4}
.cs-name{flex:1;color:#c9a8ff;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cs-diff{font-size:.68rem;padding:1px 7px;border-radius:10px;font-weight:600}
.cs-pts{margin-left:auto;font-weight:700;color:#e8d8ff}
/* mode switch row */
.mode-switch-btn{flex:1;padding:8px 0;border-radius:10px;border:1px solid #2a1060;background:#16082e;color:#6a4a9a;font-size:.85rem;font-weight:700;font-family:inherit;cursor:pointer;transition:background .15s,color .15s}
.mode-switch-btn.active{background:#2a1060;border-color:#7c4dff;color:#c9a8ff}
.mode-switch-btn:hover:not(.active){background:#1e0e3a;color:#9b78d4}
/* chaos holes — absolute positioned, moving */
.chaos-hole{position:absolute;width:80px;height:80px;background:#2a1a4a;border:1px solid #4a2e80;border-radius:16px;overflow:hidden;cursor:pointer;transition:background .1s}
.chaos-hole:hover{background:#3a2060}
.chaos-hole::after{content:'';position:absolute;bottom:0;left:0;right:0;height:28%;background:#5c3318;border-radius:0 0 16px 16px}
.chaos-hole::before{content:'';position:absolute;bottom:26%;left:0;right:0;height:8px;background:#7a4a26;border-radius:50%;z-index:1}
.chaos-hole .mole{position:absolute;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);transition:transform .18s cubic-bezier(.34,1.56,.64,1);z-index:2;pointer-events:none;width:62%}
.chaos-hole.up .mole{transform:translateX(-50%) translateY(12%)}
.chaos-hole.bonk .mole{transform:translateX(-50%) translateY(12%) rotate(-380deg) scale(.88)}
.chaos-hole .flash{position:absolute;inset:0;border-radius:16px;background:rgba(255,230,60,.35);opacity:0;pointer-events:none;z-index:5;transition:opacity .15s}
.chaos-hole.bonk .flash{opacity:1}
.chaos-hole .pop{position:absolute;top:10%;left:50%;transform:translateX(-50%);font-size:1rem;font-weight:800;color:#ffd740;opacity:0;pointer-events:none;z-index:6;white-space:nowrap}
.chaos-hole .pop.show{animation:popUp .5s ease-out forwards}
/* new hole pulse in */
@keyframes holePop{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
.chaos-hole.fresh{animation:holePop .3s cubic-bezier(.34,1.56,.64,1) forwards}
.upg-card{background:#0d1628;border:1.5px solid #1e3a6a;border-radius:14px;padding:1rem .9rem;display:flex;flex-direction:column;gap:6px;transition:border-color .15s}
.upg-card.maxed{border-color:#3a7aff;opacity:.7}
.upg-icon{font-size:1.6rem;line-height:1}
.upg-name{font-size:.85rem;font-weight:700;color:#88bbff}
.upg-desc{font-size:.72rem;color:#4a6a9a;line-height:1.4;flex:1}
.upg-level{display:flex;gap:4px;align-items:center;margin-top:2px}
.upg-pip{width:10px;height:10px;border-radius:50%;background:#1e3a6a;border:1px solid #2e5aaa;transition:background .15s}
.upg-pip.filled{background:#3a7aff;border-color:#88bbff}
.upg-effect{font-size:.72rem;color:#88bbff;font-weight:600;background:#0a1422;padding:3px 8px;border-radius:6px}
.upg-buy-btn{width:100%;padding:7px 0;font-size:.8rem;font-weight:700;font-family:inherit;border-radius:8px;cursor:pointer;transition:background .12s,opacity .12s;border:none;margin-top:2px}
.upg-buy-btn.can-buy{background:#1e3a6a;color:#88bbff;border:1px solid #3a7aff}
.upg-buy-btn.can-buy:hover{background:#2a5aaa}
.upg-buy-btn.cant-buy{background:#0a1020;color:#2a4060;border:1px solid #1a2a40;cursor:not-allowed}
.upg-buy-btn.at-max{background:#0a1a30;color:#3a7aff;border:1px solid #2a5a9a;cursor:default}
/* upgrade pills on ability bar */
.ability-pill.upgrade{border-color:#3a7aff;color:#88bbff;background:#050e1a}
.hs-empty{text-align:center;color:#5a3a80;font-size:.9rem;padding:.5rem 0}
.start-btn{padding:13px 40px;font-size:1rem;font-weight:700;font-family:inherit;letter-spacing:1px;background:#7c4dff;color:#fff;border:none;border-radius:12px;cursor:pointer;transition:background .15s,transform .1s}
.start-btn:hover{background:#9c6fff}
.start-btn:active{transform:scale(.97)}
.overlay{position:fixed;inset:0;background:rgba(10,5,25,.88);display:flex;align-items:center;justify-content:center;z-index:100}
.overlay.hidden{display:none}
.card{background:#1f1136;border:1px solid #4a2e80;border-radius:20px;padding:2.5rem 3rem;text-align:center;max-width:380px;width:90%}
.card h2{font-size:1.6rem;font-weight:800;color:#c9a8ff;margin-bottom:.4rem}
.card p{color:#9b78d4;font-size:.95rem;margin-bottom:1.4rem}
.final-score{font-size:3.5rem;font-weight:800;color:#ffd740;margin-bottom:1.4rem;display:none}
.mode-row{display:flex;gap:8px;justify-content:center;margin-bottom:1rem;flex-wrap:wrap}
.mode-btn{padding:6px 18px;border-radius:8px;border:1px solid #4a2e80;background:transparent;color:#c9a8ff;font-size:.85rem;font-family:inherit;cursor:pointer;transition:background .15s}
.mode-btn.active,.mode-btn:hover{background:#7c4dff;border-color:#7c4dff;color:#fff}
.diff-row{display:flex;gap:8px;justify-content:center;margin-bottom:1.4rem}
.diff-btn{padding:6px 16px;border-radius:8px;border:1px solid #4a2e80;background:transparent;color:#c9a8ff;font-size:.85rem;font-family:inherit;cursor:pointer;transition:background .15s}
.diff-btn.active,.diff-btn:hover{background:#7c4dff;border-color:#7c4dff;color:#fff}
.versus-scores{display:none;gap:16px;justify-content:center;margin-bottom:1.4rem}
.versus-scores.show{display:flex}
.vs-box{background:#27164a;border-radius:12px;padding:14px 22px;text-align:center;min-width:110px}
.vs-box.winner{border:2px solid #ffd740;background:#2a2000}
.vs-box .vs-label{font-size:.75rem;text-transform:uppercase;letter-spacing:1px;color:#9b78d4;margin-bottom:6px}
.vs-box .vs-pts{font-size:2.2rem;font-weight:800;color:#e8d8ff}
.vs-box.winner .vs-pts{color:#ffd740}
.vs-sep{font-size:1.6rem;font-weight:800;color:#4a2e80;align-self:center}
.key-map{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;margin:0 auto 4px;max-width:180px}
.km-key{background:#2a1060;border:1px solid #7c4dff;border-radius:6px;padding:6px 4px;text-align:center;font-size:.8rem;font-weight:700;color:#c9a8ff}
.km-note{font-size:.78rem;color:#6a4a9a;text-align:center;margin-bottom:1.4rem}
/* SHOP */
#shop-overlay .card{max-width:560px;width:96%;padding:1.6rem 1.4rem;max-height:92vh;overflow-y:auto}
.shop-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.8rem}
.shop-header h2{margin:0;font-size:1.4rem}
.shop-coins{font-size:1.1rem;font-weight:700;color:#ffd740;background:#2a1e00;border:1px solid #c8a000;border-radius:20px;padding:4px 14px}
.shop-tabs{display:flex;gap:8px;margin-bottom:1.2rem}
.shop-tab{flex:1;padding:7px;border:1px solid #4a2e80;border-radius:8px;background:transparent;color:#9b78d4;font-size:.85rem;font-family:inherit;cursor:pointer;transition:background .15s}
.shop-tab.active{background:#2a1060;border-color:#7c4dff;color:#c9a8ff;font-weight:700}
/* auto-hatch panel */
.ah-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #2a1060}
.ah-row:last-child{border-bottom:none}
.ah-label{font-size:.88rem;color:#c9a8ff;font-weight:600}
.ah-sub{font-size:.72rem;color:#6a4a9a;margin-top:2px}
.ah-toggle{position:relative;width:46px;height:26px;flex-shrink:0}
.ah-toggle input{opacity:0;width:0;height:0}
.ah-slider{position:absolute;inset:0;background:#2a1060;border-radius:26px;border:1px solid #4a2e80;cursor:pointer;transition:background .2s}
.ah-slider:before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:#6a4a9a;border-radius:50%;transition:transform .2s,background .2s}
.ah-toggle input:checked + .ah-slider{background:#1a0d3a;border-color:#7c4dff}
.ah-toggle input:checked + .ah-slider:before{transform:translateX(20px);background:#c9a8ff}
.ah-select{background:#1a0d30;border:1px solid #4a2e80;color:#c9a8ff;border-radius:8px;padding:5px 10px;font-size:.82rem;font-family:inherit;cursor:pointer;outline:none}
.ah-select:focus{border-color:#7c4dff}
.ah-speed-row{display:flex;gap:6px;flex-wrap:wrap}
.ah-speed-btn{padding:4px 11px;border-radius:7px;border:1px solid #4a2e80;background:transparent;color:#9b78d4;font-size:.78rem;font-family:inherit;cursor:pointer;transition:background .12s}
.ah-speed-btn.active{background:#2a1060;border-color:#7c4dff;color:#c9a8ff;font-weight:700}
.ah-status{margin-top:10px;padding:8px 14px;border-radius:10px;font-size:.8rem;text-align:center;font-weight:600}
.ah-status.on{background:#1a0d30;color:#a87cff;border:1px solid #4a2e80}
.ah-status.off{background:#150a28;color:#4a2e80;border:1px solid #2a1060}
.ah-progress{height:4px;background:#2a1060;border-radius:4px;margin-top:8px;overflow:hidden}
.ah-progress-fill{height:100%;background:#7c4dff;border-radius:4px;transition:width .1s linear}
/* pill on main page */
.ability-pill.autohatch{border-color:#a87cff;color:#a87cff;background:#0d0820}
.egg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1rem}
.egg-card{background:#27164a;border:1.5px solid #4a2e80;border-radius:14px;padding:.9rem .6rem;cursor:pointer;transition:border-color .15s,background .15s,transform .1s;text-align:center;position:relative}
.egg-card:hover:not(.locked){background:#35205a;transform:translateY(-2px)}
.egg-card:active:not(.locked){transform:scale(.97)}
.egg-card.locked{opacity:.5;cursor:not-allowed}
.egg-card.stone{border-color:#888}
.egg-card.mystic{border-color:#7c4dff}
.egg-card.dragon{border-color:#ff6b35}
.egg-card.donotopen{border-color:#ff6b35}
.egg-emoji{font-size:2.2rem;margin-bottom:4px}
.egg-name{font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;color:#c9a8ff}
.egg-price{font-size:.82rem;font-weight:700;color:#ffd740;background:#2a1e00;border-radius:20px;padding:3px 10px;display:inline-block;margin-bottom:8px}
.owned-badge{position:absolute;top:5px;right:5px;background:#7c4dff;color:#fff;font-size:.6rem;font-weight:700;padding:2px 5px;border-radius:8px;line-height:1}
/* odds strip inside egg card */
.odds-strip{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;margin-top:4px}
.odds-item{display:flex;align-items:center;gap:3px;font-size:.65rem;padding:2px 4px;border-radius:5px;background:#1a0d30}
.odds-item .o-emoji{font-size:.85rem;line-height:1}
.odds-item .o-pct{font-weight:700}
.odds-item.common   .o-pct{color:#a0a0a0}
.odds-item.uncommon .o-pct{color:#00e5a0}
.odds-item.rare     .o-pct{color:#55aaff}
.odds-item.legendary .o-pct{color:#ffd740}
/* collection panel */
.coll-summary{display:flex;gap:10px;margin-bottom:1rem;flex-wrap:wrap;justify-content:center}
.coll-stat{background:#1a0d30;border:1px solid #4a2e80;border-radius:10px;padding:7px 14px;text-align:center;font-size:.8rem}
.coll-stat-label{color:#6a4a9a;font-size:.7rem;letter-spacing:.5px;text-transform:uppercase;margin-bottom:2px}
.coll-stat-val{color:#e8d8ff;font-weight:700}
.coll-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.coll-card{background:#1a0d30;border-radius:10px;padding:8px 5px;text-align:center;border:1.5px solid #2a1060;position:relative}
.coll-card.common{border-color:#555}
.coll-card.uncommon{border-color:#00e5a0}
.coll-card.rare{border-color:#55aaff}
.coll-card.legendary{border-color:#ffd740;background:#1a1200}
.coll-emoji{font-size:1.6rem;margin-bottom:2px}
.coll-name{font-size:.63rem;color:#c9a8ff;font-weight:700}
.coll-rarity{font-size:.58rem;font-weight:700;margin-top:2px}
.coll-card.common   .coll-rarity{color:#a0a0a0}
.coll-card.uncommon .coll-rarity{color:#00e5a0}
.coll-card.rare     .coll-rarity{color:#55aaff}
.coll-card.legendary .coll-rarity{color:#ffd740}
.coll-count{position:absolute;top:3px;right:4px;background:#4a2e80;color:#e8d8ff;font-size:.6rem;font-weight:700;padding:1px 5px;border-radius:8px}
.coll-count.at-max{background:#ffd740;color:#1a0800}
.coll-card.stack-full{box-shadow:0 0 0 1.5px #ffd74066}
.coll-empty{text-align:center;color:#5a3a80;font-size:.9rem;padding:2rem 0}
.coll-sell-btn{display:block;width:100%;margin-top:5px;padding:3px 0;font-size:.62rem;font-weight:700;font-family:inherit;border-radius:6px;cursor:pointer;border:1px solid #4a1a00;background:#1a0800;color:#ff8c42;transition:background .12s}
.coll-sell-btn:hover{background:#2e1200;color:#ffb070}
.coll-sell-btn:active{transform:scale(.96)}
.coll-sell-price{font-size:.58rem;color:#5a3a80;margin-top:2px}
/* sell confirm overlay */
#sell-confirm{position:fixed;inset:0;background:rgba(5,2,18,.88);display:flex;align-items:center;justify-content:center;z-index:400}
#sell-confirm.hidden{display:none}
#sell-confirm .sc-card{background:#1f1136;border:1px solid #4a2e80;border-radius:16px;padding:1.8rem 2rem;text-align:center;max-width:300px;width:88%}
#sell-confirm .sc-emoji{font-size:3.5rem;margin-bottom:.3rem}
#sell-confirm .sc-name{font-size:1.2rem;font-weight:800;color:#c9a8ff;margin-bottom:.2rem}
#sell-confirm .sc-rarity{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:.7rem}
#sell-confirm .sc-price{font-size:2rem;font-weight:800;color:#ffd740;margin-bottom:.3rem}
#sell-confirm .sc-note{font-size:.78rem;color:#6a4a9a;margin-bottom:1.2rem}
.sc-btns{display:flex;gap:10px;justify-content:center}
.sc-btn-sell{padding:9px 28px;border-radius:10px;border:none;background:#7c2000;color:#ffb070;font-size:.9rem;font-weight:700;font-family:inherit;cursor:pointer;transition:background .12s}
.sc-btn-sell:hover{background:#a83000}
.sc-btn-cancel{padding:9px 20px;border-radius:10px;border:1px solid #4a2e80;background:transparent;color:#9b78d4;font-size:.9rem;font-family:inherit;cursor:pointer;transition:background .12s}
.sc-btn-cancel:hover{background:#27164a}
.close-btn{background:transparent;border:1px solid #4a2e80;color:#9b78d4;border-radius:8px;padding:8px 20px;font-family:inherit;font-size:.9rem;cursor:pointer;transition:background .15s}
.close-btn:hover{background:#27164a}
/* HATCH OVERLAY */
#hatch-overlay{position:fixed;inset:0;background:rgba(5,2,15,.97);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:300;gap:0;transition:background .4s}
#hatch-overlay.hidden{display:none}
#hatch-overlay.uncommon-bg{background:rgba(0,18,10,.97)}
#hatch-overlay.rare-bg{background:rgba(0,5,28,.97)}
#hatch-overlay.legendary-bg{background:rgba(18,12,0,.97)}
#hatch-egg{font-size:6rem;margin-bottom:1rem;display:block;animation:eggWobble .4s ease-in-out infinite alternate}
#hatch-egg.cracking{animation:eggCrack .8s ease-in-out forwards}
@keyframes eggWobble{from{transform:rotate(-8deg) scale(1)}to{transform:rotate(8deg) scale(1.05)}}
@keyframes eggCrack{0%{transform:rotate(0) scale(1)}20%{transform:rotate(-15deg) scale(1.1)}40%{transform:rotate(15deg) scale(1.15)}60%{transform:rotate(-10deg) scale(1.2)}80%{transform:rotate(5deg) scale(1.3)}100%{transform:rotate(0) scale(0);opacity:0}}
#hatch-animal{font-size:7rem;display:none;animation:animalPop .6s cubic-bezier(.34,1.56,.64,1) forwards;margin-bottom:.3rem}
@keyframes animalPop{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
#hatch-name{font-size:1.8rem;font-weight:900;letter-spacing:2px;color:#c9a8ff;display:none;margin-bottom:.3rem}
#hatch-rarity-badge{font-size:.9rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;padding:4px 18px;border-radius:20px;display:none;margin-bottom:.5rem}
#hatch-rarity-badge.common{background:#222;color:#a0a0a0;border:1px solid #555}
#hatch-rarity-badge.uncommon{background:#001a0d;color:#00e5a0;border:1px solid #00e5a0}
#hatch-rarity-badge.rare{background:#00082a;color:#55aaff;border:1px solid #55aaff}
#hatch-rarity-badge.legendary{background:#1a1000;color:#ffd740;border:1px solid #ffd740;animation:legendaryBadgePulse 1.2s infinite}
@keyframes legendaryBadgePulse{0%,100%{box-shadow:0 0 8px #ffd74066}50%{box-shadow:0 0 28px #ffd740cc}}
#hatch-pct{font-size:.8rem;color:#5a3a80;display:none;margin-bottom:.4rem}
#hatch-ability-text{font-size:.95rem;color:#9b78d4;display:none;text-align:center;max-width:280px;line-height:1.5;margin-bottom:.4rem}
#hatch-status{font-size:.85rem;font-weight:700;display:none;margin-bottom:1rem;padding:4px 14px;border-radius:20px}
#hatch-status.new-animal{background:#00150d;color:#00e5a0;border:1px solid #00e5a066}
#hatch-status.duplicate{background:#2a1e00;color:#ffd740;border:1px solid #ffd74066}
#hatch-status.maxed{background:#3a0800;color:#ff6b35;border:1px solid #ff6b3580;font-size:.8rem}
#hatch-tap{font-size:.85rem;color:#5a3a80;display:none;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
/* legendary sparkles */
.sparkle{position:fixed;pointer-events:none;font-size:1.4rem;animation:sparkleFly 1.8s ease-out forwards;z-index:301}
@keyframes sparkleFly{0%{opacity:1;transform:translate(0,0) scale(1)}100%{opacity:0;transform:var(--tx) scale(0)}}
@keyframes shake{0%,100%{transform:translateX(0)}15%{transform:translateX(-10px) rotate(-2deg)}30%{transform:translateX(10px) rotate(2deg)}45%{transform:translateX(-8px) rotate(-1deg)}60%{transform:translateX(8px) rotate(1deg)}75%{transform:translateX(-4px)}90%{transform:translateX(4px)}}
@keyframes bannerPop{0%{opacity:0;transform:translate(-50%,-50%) scale(.4) rotate(-8deg)}15%{opacity:1;transform:translate(-50%,-50%) scale(1.18) rotate(4deg)}30%{transform:translate(-50%,-50%) scale(1) rotate(-2deg)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.06) rotate(1deg)}75%{opacity:1;transform:translate(-50%,-50%) scale(1)}90%{opacity:.8;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-50%) scale(.85)}}
.grid.shaking{animation:shake .6s ease-in-out}
/* mole dance */
@keyframes moleDance{
  0%  {transform:translateX(-50%) translateY(12%) rotate(0deg)   scale(1)}
  10% {transform:translateX(-50%) translateY(4%)  rotate(-18deg) scale(1.12)}
  22% {transform:translateX(-50%) translateY(12%) rotate(14deg)  scale(0.95)}
  35% {transform:translateX(-50%) translateY(2%)  rotate(-22deg) scale(1.15)}
  48% {transform:translateX(-50%) translateY(12%) rotate(16deg)  scale(0.93)}
  60% {transform:translateX(-50%) translateY(0%)  rotate(-14deg) scale(1.1)}
  72% {transform:translateX(-50%) translateY(10%) rotate(10deg)  scale(0.97)}
  85% {transform:translateX(-50%) translateY(5%)  rotate(-8deg)  scale(1.06)}
  100%{transform:translateX(-50%) translateY(12%) rotate(0deg)   scale(1)}
}
.hole.dancing .mole{animation:moleDance 0.55s ease-in-out var(--dance-delay,0s) 5 alternate}
#distraction-banner{position:fixed;top:40%;left:50%;transform:translate(-50%,-50%);background:#ff3cac;color:#fff;font-size:2.4rem;font-weight:900;letter-spacing:4px;padding:16px 36px;border-radius:20px;z-index:200;pointer-events:none;display:none;white-space:nowrap;text-shadow:0 2px 12px #0008}
#distraction-banner.show{display:block;animation:bannerPop 4s ease-out forwards}
.hole.key-flash{background:#3a1030 !important}
/* ═══ GIANT HAMMER ═══════════════════════════════════════════════════════════*/
#hammer{position:fixed;z-index:55;pointer-events:none;display:none;width:110px;transform-origin:50% 80%}
#hammer.slamming{animation:hammerSlam 0.44s cubic-bezier(0.22,1,0.36,1) forwards}
@keyframes hammerSlam{
  0%  {transform:rotate(62deg);opacity:1}
  28% {transform:rotate(-11deg);opacity:1}
  42% {transform:rotate(-4deg);opacity:1}
  56% {transform:rotate(-9deg);opacity:1}
  70% {transform:rotate(-2deg);opacity:1}
  84% {transform:rotate(-30deg);opacity:.8}
  100%{transform:rotate(68deg);opacity:0}
}
/* ═══ FLYING MOLE ════════════════════════════════════════════════════════════*/
.mole-launch{animation:moleLaunch 1.05s cubic-bezier(0.25,0.46,0.45,0.94) forwards;transform-origin:center center;width:100%;height:100%}
.mole-launch svg{width:100%;height:auto;display:block}
@keyframes moleLaunch{
  0%  {transform:translate(0,0) rotate(0deg) scale(1);opacity:1}
  7%  {transform:translate(0,-14px) rotate(calc(var(--spin)*0.04)) scale(1.35);opacity:1}
  100%{transform:translate(var(--fly-x),var(--fly-y)) rotate(var(--spin)) scale(0.04);opacity:0}
}
/* ═══ IMPACT SPARKS ══════════════════════════════════════════════════════════*/
.spark{position:fixed;pointer-events:none;z-index:56;font-size:1.4rem;line-height:1;animation:sparkFly 0.55s ease-out forwards}
@keyframes sparkFly{
  0%  {transform:translate(0,0) scale(1.2);opacity:1}
  100%{transform:translate(var(--sx),var(--sy)) scale(0);opacity:0}
}
/* ═══ SCREEN SHAKE ═══════════════════════════════════════════════════════════*/
@keyframes screenShakeAnim{
  0%,100%{transform:translate(0,0) rotate(0deg)}
  18%{transform:translate(-5px,3px) rotate(-0.4deg)}
  36%{transform:translate(5px,-3px) rotate(0.4deg)}
  54%{transform:translate(-4px,4px) rotate(-0.3deg)}
  72%{transform:translate(4px,-2px) rotate(0.3deg)}
}
body.screen-shaking{animation:screenShakeAnim 0.22s ease-in-out}
@keyframes timerFlash{0%{color:#55ffcc;transform:scale(1.3)}60%{color:#55ffcc;transform:scale(1.1)}100%{color:#e8d8ff;transform:scale(1)}}
.timer-gained{animation:timerFlash .5s ease-out forwards}
/* ═══ BASEBALL BAT ═══════════════════════════════════════════════════════════*/
#baseball-bat{position:fixed;z-index:55;pointer-events:none;display:none;width:210px;transform-origin:100% 50%}
#baseball-bat.swinging{animation:batSwing 0.42s cubic-bezier(0.22,1,0.36,1) forwards}
@keyframes batSwing{
  0%  {transform:rotate(-40deg);opacity:1}
  30% {transform:rotate(7deg);opacity:1}
  50% {transform:rotate(24deg);opacity:1}
  68% {transform:rotate(18deg);opacity:.8}
  100%{transform:rotate(-8deg);opacity:0}
}
/* ═══ MONSTER TAIL ═══════════════════════════════════════════════════════════*/
#monster-tail{position:fixed;z-index:55;pointer-events:none;display:none;width:88px;transform-origin:50% 100%}
#monster-tail.whipping{animation:tailWhip 0.52s cubic-bezier(0.22,1,0.36,1) forwards}
@keyframes tailWhip{
  0%  {transform:rotate(52deg) translateY(24px);opacity:0}
  12% {transform:rotate(52deg) translateY(0);opacity:1}
  38% {transform:rotate(-6deg) translateY(-6px);opacity:1}
  62% {transform:rotate(-42deg);opacity:1}
  80% {transform:rotate(-50deg);opacity:.5}
  100%{transform:rotate(-50deg) translateY(28px);opacity:0}
}
/* ═══ MILESTONE BANNER ═══════════════════════════════════════════════════════*/
#milestone-banner{position:fixed;top:14%;left:50%;transform:translateX(-50%) scale(0);font-size:1.9rem;font-weight:900;letter-spacing:3px;padding:12px 30px;border-radius:18px;z-index:210;pointer-events:none;white-space:nowrap;text-shadow:0 2px 10px #0008;display:none}
#milestone-banner.show-bat{display:block;background:#4a1e00;color:#ffd740;border:2px solid #c8811a;animation:milestonePop 1.1s ease-out forwards}
#milestone-banner.show-tail{display:block;background:#22004a;color:#d0aaff;border:2px solid #8a35d0;animation:milestonePop 1.1s ease-out forwards}
@keyframes milestonePop{
  0%  {transform:translateX(-50%) scale(0.3) rotate(-6deg);opacity:0}
  18% {transform:translateX(-50%) scale(1.14) rotate(2deg);opacity:1}
  35% {transform:translateX(-50%) scale(1) rotate(0);opacity:1}
  75% {transform:translateX(-50%) scale(1);opacity:1}
  100%{transform:translateX(-50%) scale(0.85);opacity:0}
}
/* ═══ PARKOUR MODE ═══════════════════════════════════════════════════════════*/
#pkCanvas{background:linear-gradient(180deg,#1a0a2a 0%,#2a1a4a 100%)}
</style>
</head>
