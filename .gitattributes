}
let ckLastTime = 0;
function ckLoop(ts) {
  const dt = Math.min((ts - ckLastTime) / 1000, 0.05);
  ckLastTime = ts;
  const area = document.getElementById('chaos-area');
  if (!area) { CK.rafId = requestAnimationFrame(ckLoop); return; }
  const AW = area.offsetWidth || 500;
  const AH = area.offsetHeight || 480;
  CK.holes.forEach(h => {
    h.x += h.vx * dt; h.y += h.vy * dt;
    if (h.x < 4)           { h.x = 4;           h.vx =  Math.abs(h.vx); }
