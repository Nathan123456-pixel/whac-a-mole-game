const CK = { running:false, score:0, startTime:0, holes:[], rafId:null, holeSpawnTimer:null, moleSpawnTimer:null };
const CK_START_HOLES = 4;
const CK_MAX_HOLES   = 14;
const HOLE_SIZE      = 80;
function ckMakeHole() {
  const area = document.getElementById('chaos-area');
  const AW = area.offsetWidth  || 500;
  const AH = area.offsetHeight || 480;
  const x = 28 + Math.random() * (AW - HOLE_SIZE - 56);
  const y = 32 + Math.random() * (AH - HOLE_SIZE - 60);
  const angle = Math.random() * Math.PI * 2;
  const spd   = 22 + Math.random() * 35;
  const id = 'ck_' + Date.now() + '_' + Math.random();
  const el = document.createElement('div');
  el.className = 'chaos-hole fresh';
  el.style.left = x+'px'; el.style.top = y+'px';
  el.innerHTML = `<div class="mole">${moleMarkup()}</div><div class="flash"></div><div class="pop">+1</div>`;
  area.appendChild(el);
  setTimeout(() => el.classList.remove('fresh'), 350);
  const h = { el, x, y, vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd,
    up: false, moleTimer: null, id };
  el.addEventListener('click', () => ckWhack(h));
  CK.holes.push(h);
  return h;
}
function ckRaiseMole(h) {
