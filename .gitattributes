  if (h.el) h.el.classList.remove('up','bonk');
}
function ckWhack(h) {
  if (!CK.running || !h.up) return;
  clearTimeout(h.moleTimer); h.up = false;
  h.el.classList.remove('up'); h.el.classList.add('bonk');
  setTimeout(() => { if(h.el) h.el.classList.remove('bonk'); }, 110);
