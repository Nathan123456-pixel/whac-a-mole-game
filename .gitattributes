  saveHighScore(s, diff, 'parkour');
  
  document.getElementById('card-title').textContent = '🏃 Parkour Complete!';
  document.getElementById('card-msg').textContent = `You whacked ${s} mole${s!==1?'s':''}!`;
  const fs = document.getElementById('final-score');
  fs.textContent = s + ' pts';
  fs.style.display = 'block';
  document.getElementById('versus-scores').classList.remove('show');
  document.getElementById('play-btn').textContent = '↺ Play Again';
  document.getElementById('overlay').classList.remove('hidden');
}
